    <script>
      // Detect stale asset filenames after deployment (new content hashes).
      // When the browser holds a cached index.html pointing to old hashed JS/CSS,
      // the server 404s those files and returns the SPA HTML — causing a MIME
      // type mismatch error. Reload the page to pick up the updated index.html.
      window.addEventListener('error', function(e) {
        var t = e.target;
        if (t && (t.tagName === 'SCRIPT' || t.tagName === 'LINK')) {
          var src = t.src || t.href || '';
          if (src.indexOf(window.location.origin) === 0 || (src.indexOf('/') === 0 && src.indexOf('//') !== 0)) {
            window.location.reload();
          }
        }
      }, true);
      // Also handle Vite's dynamic import() failures (lazy-loaded chunks).
      window.addEventListener('vite:preloadError', function() {
        window.location.reload();
      });
    </script>
